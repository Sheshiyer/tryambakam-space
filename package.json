{
  "name": "tryambakam-noesis-infinite-canvas",
  "private": true,
  "version": "1.0.0",
  "description": "13-wing interactive consciousness architecture — infinite 3D canvas with bespoke templates, modals, WCAG AA, and code splitting",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "check:types": "tsc --noEmit -p tsconfig.app.json",
    "check:biome": "biome lint --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
    "check": "npm run check:types && npm run check:biome",
    "lint": "npm run check:biome",
    "format": "biome check --write --unsafe",
    "preview": "vite preview",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.4.2",
    "gsap": "3.14.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "0.182.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@playwright/test": "1.58.2",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "sharp": "0.34.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.7"
  }
}
